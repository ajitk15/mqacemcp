# =============================================================================
# Log-insights dashboard — environment variables
#
# Standalone HTTP server that renders the MQ+ACE query-log dashboard.
# It imports config from the MCP server's `server` package and reads the
# same LOG_DIR. TLS certs are shared with the MCP server.
#
# Copy to `.env` and adjust as needed. Do NOT commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Dashboard bind settings
# -----------------------------------------------------------------------------
# Bind address and port for the standalone dashboard HTTP server.
# Defaults if unset: host=0.0.0.0, port=8002. Endpoints: /dashboard, /healthz.
# Use 8004 to avoid colliding with the chat backend (8002) and Streamlit (8003).
MCP_DASHBOARD_HOST=0.0.0.0
MCP_DASHBOARD_PORT=8004

# -----------------------------------------------------------------------------
# MCP server directory override
# -----------------------------------------------------------------------------
# By default the dashboard imports `server.config` / `server.logger` from
# `../mqacemcpserver/`. Override to point at the single-build's server package.
MCP_SERVER_DIR=../mqacemcpserver-single

# -----------------------------------------------------------------------------
# Shared config (read via the MCP server's `server.config` module)
# -----------------------------------------------------------------------------
# These variables are loaded by the server.config module that the dashboard
# imports. They control which log files the dashboard reads and TLS settings.

# Logging level. One of DEBUG/INFO/WARNING/ERROR.
MQACE_LOG_LEVEL=INFO

# Directory containing query logs. Must match the MCP server's LOG_DIR so the
# dashboard reads the same data the server writes.
LOG_DIR=../mqacemcpserver-single/logs

# Days to retain rotated log files.
LOG_RETENTION_DAYS=30

# Optional TLS for the dashboard endpoint. Shares certs with the MCP server.
# BOTH cert and key must be set to enable HTTPS; otherwise falls back to HTTP.
MCP_TLS_CERT=../certs/cert.pem
MCP_TLS_KEY=../certs/key.pem

# =============================================================================
# Chatbot backend — plug-and-play config
#
# This service is generic: it speaks to any MCP server over SSE.
# To swap MCP servers, change MCP_SSE_URL (and the auth vars below).
# =============================================================================

# --- LLM ---------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- MCP server -------------------------------------------------------------
# Full SSE URL of any MCP server. Examples:
#   http://localhost:8000/sse
#   https://mcp.example.com/sse
MCP_SSE_URL=http://localhost:8000/sse

# Optional Basic Auth (used when both are set).
MCP_AUTH_USER=
MCP_AUTH_PASSWORD=

# Optional escape hatch for non-Basic auth schemes (Bearer tokens, custom
# headers). JSON object, merged on top of Basic Auth if both are set.
# Example: {"Authorization": "Bearer eyJhbGciOi...", "X-Tenant": "acme"}
MCP_HEADERS_JSON=

# --- UI header --------------------------------------------------------------
# Customize the chat UI header. The frontend reads these from /api/health, so
# changes take effect after restarting only the backend (no rebuild needed).
#   HEADER_TITLE:    main title text (default "MCP Chatbot")
#   HEADER_SUBTITLE: optional override; when empty the UI auto-derives it from
#                    BOT_DOMAIN below (e.g. "scope: IBM MQ and IBM ACE")
HEADER_TITLE=IBM MQ and ACE assistant
HEADER_SUBTITLE=

# --- Bot scope --------------------------------------------------------------
# Restrict the bot to a domain. The LLM refuses off-topic questions without
# invoking any tools, and the frontend shows the scope as a header subtitle.
# Leave empty to disable the restriction (preserves plug-and-play).
BOT_DOMAIN=IBM MQ and IBM ACE

# --- System prompt ----------------------------------------------------------
# Optional override path for the system prompt template (Markdown).
# Default: chatbot/backend/prompts/system.md (auto-discovered when present).
# Resolution order: this env path -> default file -> inline fallback in agent.py.
# The template MUST contain both {scope_block} and {tool_catalog} placeholders.
# It MAY contain {support_team}, which is substituted from SUPPORT_TEAM below.
SYSTEM_PROMPT_FILE=

# Name of the human team the bot escalates to in the system prompt
# (substituted wherever the template uses {support_team}). Leave empty to
# fall back to the literal "MQ_ACE_SUPPORT". Examples:
#   SUPPORT_TEAM=MQ_ACE_SUPPORT
#   SUPPORT_TEAM=Middleware On-Call
#   SUPPORT_TEAM=#mq-ace-help on Slack
SUPPORT_TEAM=

# --- Tool surface control ---------------------------------------------------
# Both lists are comma-separated MCP tool names. Leave empty for no filtering.
#   TOOL_ALLOWLIST: when non-empty, ONLY these tools are exposed to the agent.
#   TOOL_DENYLIST:  always removed (wins over allowlist for the same name).
# The agent literally cannot call a tool that has been filtered out.
TOOL_ALLOWLIST=
TOOL_DENYLIST=

# --- Chat service binding ---------------------------------------------------
CHAT_HOST=0.0.0.0
CHAT_PORT=8001

# Comma-separated origins allowed to call this backend.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# Chatbot backend — plug-and-play config
#
# This service is generic: it speaks to any MCP server over SSE.
# To swap MCP servers, change MCP_SSE_URL (and the auth vars below).
# =============================================================================

# --- LLM ---------------------------------------------------------------------
# OpenAI API key. Required.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-5.4

# --- MCP server -------------------------------------------------------------
# Full URL of the DEFAULT MCP server activated at startup. Examples:
#   https://localhost:8010/mcp   (mqacemcpserver, streamable-http)
#   https://localhost:8010/sse   (legacy SSE transport)
#   https://mcp.example.com/mcp
# scripts/start-all runs the MCP server; the sidebar can switch to a custom one.
MCP_SSE_URL=https://localhost:8010/mcp

# Default MCP transport: "streamable_http" (recommended) or "sse" (legacy).
# Must match how the MCP server is started (its MCP_TRANSPORT). A "-" is accepted
# too (e.g. streamable-http). Per-server overrides may set "transport" in the
# registry below.
MCP_TRANSPORT=streamable_http

# Registry of selectable MCP servers for the frontend dropdown (single-line
# JSON array). Each: name, url, prompt_file, default, and optional transport.
# Falls back to a single entry from MCP_SSE_URL when unset/invalid.
MCP_SERVERS_JSON=[{"name":"mqacemcpserver (:8010)","url":"https://localhost:8010/mcp","prompt_file":"backend/prompts/system.md","default":true}]

# Optional Basic Auth (used when both are set). Must match MCP server's
# MCP_AUTH_USER / MCP_AUTH_PASSWORD.
MCP_AUTH_USER=mcpadmin
MCP_AUTH_PASSWORD=mcpadmin

# Optional path to a PEM CA bundle used to verify the MCP server's TLS cert
# (useful for self-signed dev certs). Relative paths resolve against the repo
# root. Leave blank to use the system trust store.
MCP_TLS_CA_BUNDLE=../certs/cert.pem

# Optional escape hatch for non-Basic auth schemes (Bearer tokens, custom
# headers). JSON object, merged on top of Basic Auth if both are set.
# Example: {"Authorization": "Bearer eyJhbGciOi...", "X-Tenant": "acme"}
MCP_HEADERS_JSON=

# --- UI header --------------------------------------------------------------
# Customize the chat UI header. The frontend reads these from /api/health, so
# changes take effect after restarting only the backend (no rebuild needed).
#   HEADER_TITLE:    main title text (default "MCP Chatbot")
#   HEADER_SUBTITLE: optional override; when empty the UI auto-derives it from
#                    BOT_DOMAIN below (e.g. "scope: IBM MQ and IBM ACE")
HEADER_TITLE=IBM MQ and ACE assistant
HEADER_SUBTITLE=

# --- Bot scope --------------------------------------------------------------
# Restrict the bot to a domain. The LLM refuses off-topic questions without
# invoking any tools, and the frontend shows the scope as a header subtitle.
# Leave empty to disable the restriction (preserves plug-and-play).
BOT_DOMAIN=IBM MQ, IBM ACE, and TLS/SSL certificates

# --- System prompt ----------------------------------------------------------
# Optional override path for the system prompt template (Markdown).
# Default: backend/prompts/system.md (auto-discovered when present).
# Resolution order: this env path -> default file -> inline fallback in agent.py.
# The template MUST contain both {scope_block} and {tool_catalog} placeholders.
# It MAY contain {support_team}, which is substituted from SUPPORT_TEAM below.
# Leave unset to use the default backend/prompts/system.md.
# SYSTEM_PROMPT_FILE=backend/prompts/system.md

# Name of the human team the bot escalates to in the system prompt
# (substituted wherever the template uses {support_team}). Leave empty to
# fall back to the literal "MQ_ACE_SUPPORT". Examples:
#   SUPPORT_TEAM=MQ_ACE_SUPPORT
#   SUPPORT_TEAM=Middleware On-Call
#   SUPPORT_TEAM=#mq-ace-help on Slack
SUPPORT_TEAM=MQ_ACE_SUPPORT

# --- Tool surface control ---------------------------------------------------
# Both lists are comma-separated MCP tool names. Leave empty for no filtering.
#   TOOL_ALLOWLIST: when non-empty, ONLY these tools are exposed to the agent.
#   TOOL_DENYLIST:  always removed (wins over allowlist for the same name).
# The agent literally cannot call a tool that has been filtered out.
TOOL_ALLOWLIST=
TOOL_DENYLIST=

# --- Chat service binding ---------------------------------------------------
CHAT_HOST=0.0.0.0
CHAT_PORT=8002

# Comma-separated origins allowed to call this backend. (The Streamlit UI
# calls the backend server-side via httpx, so browser CORS does not apply to
# it; this only matters if a browser-origin client calls the backend directly.)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8003
